{
  "name": "writing-coach",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
"test:watch": "vitest",
    "electron:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_RENDERER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:dir": "npm run build && electron-builder --dir",
    "generate:mobile-data": "node scripts/generate-mobile-data.cjs",
    "mobile": "cd mobile && npm start",
    "mobile:android": "cd mobile && npx expo start --android",
    "mobile:ios": "cd mobile && npx expo start --ios"
  },
  "dependencies": {
    "@xenolexia/dict": "file:../packages/xenolexia-dict",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "jsdom": "^25.0.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "~5.6.2",
    "vite": "^5.4.10",
    "vite-plugin-pwa": "^0.20.0",
    "vitest": "^2.1.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "app.xenolexia.writing-coach",
    "productName": "Writing Coach",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*"],
    "extraResources": [],
    "mac": { "category": "public.app-category.productivity", "target": ["dmg", "zip"] },
    "win": { "target": ["nsis", "portable"] },
    "linux": { "target": ["AppImage", "deb"] }
  }
}
